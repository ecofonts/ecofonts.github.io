---
// Ecofonts landing page. The drop zone stashes the file in IndexedDB
// (src/lib/handoff.ts) and redirects to /font, which picks it up.
import Base from "../layouts/Base.astro";

const site = "https://ecofonts.github.io";

// Structured data for rich search results. The FAQ entries must mirror the
// visible FAQ section below — search engines penalize mismatches.
const webAppSchema = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	name: "Ecofonts",
	url: `${site}/`,
	image: `${site}/og.png`,
	applicationCategory: "UtilitiesApplication",
	operatingSystem: "Any",
	browserRequirements: "Requires a modern web browser with JavaScript",
	description:
		"Optimize PDFs and fonts to print with less ink — 100% in your browser. Your files never leave your machine.",
	offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
	featureList: [
		"Optimize every embedded font in a PDF",
		"Optimize .ttf, .otf, .woff and .woff2 fonts and .zip font families",
		"Adjustable ink savings from 1% to 20%",
		"Runs entirely client-side — no uploads",
	],
};

const faq = [
	[
		"How does this work?",
		"Ecofonts reads the vector outlines of every glyph — in a PDF, from each embedded font — then subtracts a fine grid of tiny holes from the interior of each letter using boolean geometry. The outer silhouette of every letter is left untouched, and the modified outlines are compiled back into the file you uploaded.",
	],
	[
		"Can I optimize a whole PDF?",
		"Yes. Drop a .pdf and Ecofonts finds every embedded font in the document — TrueType, CFF/OpenType, and legacy Type 1 alike — punches the eco holes into its glyphs, and rebuilds the file. The layout, images, and text stay exactly as they were — the text even remains selectable.",
	],
	[
		"Does this work completely on my computer?",
		"Yes — 100%. There is no server: parsing, geometry, and packaging all run in your browser. Your files are never uploaded anywhere, and the page even works offline once it has loaded.",
	],
	[
		"Which files are supported?",
		"A .pdf document, a single font in .ttf, .otf, .woff or .woff2 format, or a .zip archive containing fonts — including nested folders such as the static/ directory in Google Fonts downloads. Archives come back with their exact structure preserved, and web fonts come back in the format they arrived in.",
	],
	[
		"How do I use a font from Google Fonts?",
		"Download the family from fonts.google.com (Get font → Download all) and drop the resulting .zip on Ecofonts. Every weight and style inside is optimized and the archive keeps its structure.",
	],
	[
		"Will my text still look good?",
		"Yes. A minimum wall of ink is always preserved around every hole, so the edges of each letter stay solid and sharp. At typical reading sizes the holes are too small to notice.",
	],
	[
		"How much ink can I actually save?",
		"The Eco Intensity slider goes from 1% to 20%, and it maps to the real share of printed area removed from the letters — at 15% intensity, roughly 15% less ink goes on the page for the same text.",
	],
	[
		"What about variable fonts?",
		"Variable fonts are processed as their default style. For a full family (Bold, Light, Italic…), upload the whole zip — the fixed-weight fonts in its static/ folder carry every style through.",
	],
	[
		"Am I allowed to modify a font?",
		"That depends on the font's license. Open licenses like the SIL Open Font License explicitly allow modification. For commercial fonts, check your license terms first.",
	],
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faq.map(([question, answer]) => ({
		"@type": "Question",
		name: question,
		acceptedAnswer: { "@type": "Answer", text: answer },
	})),
};
---

<Base
	title="Ecofonts — Save Ink, Save the planet"
	description="Drop a PDF and Ecofonts rewrites every embedded font with microscopic ink-saving holes — 100% in your browser. Fonts and font families work too."
>
	<a slot="nav-actions" class="btn" href="/font">Open the optimizer</a>

	<script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} is:inline />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

	<header class="hero">
		<p class="badge">100% in your browser — nothing gets uploaded</p>
		<h1>Save Ink, <span class="accent">Save the planet</span></h1>
		<p class="tagline">
			Drop a PDF and Ecofonts rewrites every font inside it with microscopic holes your eyes
			never notice — but your printer does. Same document, same look, up to 20% less ink.
			Fonts and whole font families work too.
		</p>

		<div
			id="dropzone"
			role="button"
			tabindex="0"
			aria-label="Drop .pdf, .zip or font files here, or press Enter to browse"
		>
			<img src="/favicon.svg" alt="" width="52" height="52" />
			<p><strong>Drop your PDFs here</strong></p>
			<p class="hint">.pdf, .zip, .ttf, .otf, .woff or .woff2 — multiple files welcome</p>
			<input id="drop-input" type="file" accept=".pdf,.zip,.ttf,.otf,.woff,.woff2" multiple hidden />
		</div>
		<p id="drop-error" role="alert" hidden></p>

		<ul class="stats">
			<li>Up to <strong>20% less ink</strong></li>
			<li><strong>Private</strong> by design</li>
			<li><strong>Free</strong> and open source</li>
		</ul>
	</header>

	<main>
		<section>
			<h2>How it works</h2>
			<div class="grid three">
				<article class="card">
					<span class="step">1</span>
					<h3>Upload</h3>
					<p>
						Drop a <code>.pdf</code> document — every embedded font gets optimized. A single
						font (<code>.ttf</code>, <code>.otf</code>, <code>.woff</code>, <code
						>.woff2</code>) or a whole <code>.zip</code> family works just as well.
					</p>
				</article>
				<article class="card">
					<span class="step">2</span>
					<h3>Tune</h3>
					<p>
						Pick your Eco Intensity from 1% to 20%. The value is honest — it's the measured
						share of ink actually removed from the letters.
					</p>
				</article>
				<article class="card">
					<span class="step">3</span>
					<h3>Download</h3>
					<p>
						Get the same file back — identical name, structure, and layout — ready to print
						lighter on ink.
					</p>
				</article>
			</div>
		</section>

		<section class="alt">
			<h2>Why Ecofonts?</h2>
			<div class="grid four">
				<article class="card">
					<h3>🖨️ Whole PDFs, one drop</h3>
					<p>
						Reports, invoices, handouts — drop the finished PDF and every embedded font is
						rewritten in place. Layout untouched, text still selectable.
					</p>
				</article>
				<article class="card">
					<h3>🔒 Private by design</h3>
					<p>
						No uploads, no servers, no accounts. Parsing, geometry, and packaging all happen on
						your machine.
					</p>
				</article>
				<article class="card">
					<h3>👓 Invisible at print size</h3>
					<p>
						The holes are tiny and never touch the outline of a letter, so text stays crisp and
						legible at reading sizes.
					</p>
				</article>
				<article class="card">
					<h3>✒️ Honest ink savings</h3>
					<p>
						The intensity you choose is the ink you save — we measure the actual area removed
						from every glyph, not a marketing number.
					</p>
				</article>
			</div>
		</section>

		<section id="google-fonts">
			<h2>Using a font from Google Fonts</h2>
			<p class="section-lede">
				No integration needed — Google Fonts already gives you exactly what Ecofonts eats.
			</p>
			<ol class="gf-steps">
				<li>
					<strong>Find your font</strong> on <a
						href="https://fonts.google.com"
						target="_blank"
						rel="noopener noreferrer">fonts.google.com</a
					> and open its page.
				</li>
				<li>
					<strong>Click “Get font”, then “Download all”.</strong> You'll get a <code>.zip</code> with
					every weight and style of the family.
				</li>
				<li>
					<strong>Drop that <code>.zip</code> right here.</strong> Ecofonts optimizes each font
					inside — including the fixed-weight copies in the <code>static/</code> folder — and
					returns the archive with its structure intact, ready to install.
				</li>
			</ol>
		</section>

		<section id="mission" class="alt">
			<h2>The Mission</h2>
			<p class="section-lede">
				Ecofonts exists because the liquid your printer lays on every page is one of the most
				expensive — and most oil-hungry — you will ever buy.
			</p>
			<div class="grid three">
				<article class="card">
					<h3>💎 Pricier than champagne</h3>
					<p>
						Liter for liter, branded printer ink is estimated to cost well over $1,000 —
						several times the price of vintage champagne, and orders of magnitude more than
						the petrol at the pump. Every drop a page doesn't need is money that stays in
						your pocket.
					</p>
				</article>
				<article class="card">
					<h3>🛢️ Ink starts as petroleum</h3>
					<p>
						Carbon-black pigment, solvents, and toner polymers are all derived from crude
						oil — and so is the plastic cartridge around them. Manufacturing a single new
						laser cartridge is estimated to consume around three liters of oil before it
						ever touches paper.
					</p>
				</article>
				<article class="card">
					<h3>🌍 Small holes, planetary scale</h3>
					<p>
						Well over a billion cartridges are sold every year, and most end up in landfill.
						If the world's documents used 20% less ink, cartridges would last that much
						longer — hundreds of millions of liters of oil never drilled, refined, or
						shipped, and the CO₂ from all of it never emitted.
					</p>
				</article>
			</div>
			<p class="mission-close">Same page, same look — just less oil on it. That's the mission.</p>
		</section>

		<section id="faq">
			<h2>FAQ</h2>
			<p class="section-lede">Everything you might wonder before dropping your first file.</p>
			<div class="faq-list">
				<details>
					<summary>How does this work?</summary>
					<p>
						Ecofonts reads the vector outlines of every glyph — in a PDF, from each embedded
						font — then subtracts a fine grid of tiny holes from the interior of each letter
						using boolean geometry, the same kind of operation vector editors use. The outer
						silhouette of every letter is left untouched, so shapes stay recognizable. The
						modified outlines are compiled back into the file you uploaded.
					</p>
				</details>
				<details>
					<summary>Can I optimize a whole PDF?</summary>
					<p>
						Yes — that's the main event. Drop a <code>.pdf</code> and Ecofonts finds every
						embedded font in the document — TrueType, CFF/OpenType, and legacy Type&nbsp;1
						alike — punches the eco holes into its glyphs, and rebuilds the file. The layout,
						images, and text stay exactly as they were — the text even remains selectable.
					</p>
				</details>
				<details>
					<summary>Does this work completely on my computer?</summary>
					<p>
						Yes — 100%. There is no server: parsing, geometry, and packaging all run in your
						browser. Your files are never uploaded anywhere, and the page even works offline
						once it has loaded.
					</p>
				</details>
				<details>
					<summary>Which files are supported?</summary>
					<p>
						A <code>.pdf</code> document, a single font in <code>.ttf</code>, <code
						>.otf</code>, <code>.woff</code> or <code>.woff2</code> format, or a <code
						>.zip</code> archive containing fonts — including nested folders such as the
						<code>static/</code> directory in Google Fonts downloads. Archives come back
						with their exact structure preserved, and web fonts come back in the format
						they arrived in.
					</p>
				</details>
				<details>
					<summary>How do I use a font from Google Fonts?</summary>
					<p>
						Download the family from fonts.google.com (“Get font” → “Download all”) and drop
						the resulting <code>.zip</code> here — see the <a href="#google-fonts"
						>step-by-step guide</a> above.
					</p>
				</details>
				<details>
					<summary>Will my text still look good?</summary>
					<p>
						Yes. A minimum “wall” of ink is always preserved around every hole, so the edges of
						each letter stay solid and sharp. At typical reading sizes the holes are too small
						to notice — they simply let your printer skip ink the eye never misses.
					</p>
				</details>
				<details>
					<summary>How much ink can I actually save?</summary>
					<p>
						The Eco Intensity slider goes from 1% to 20%, and it maps to the real share of
						printed area removed from the letters — at 15% intensity, roughly 15% less ink goes
						on the page for the same text.
					</p>
				</details>
				<details>
					<summary>What about variable fonts?</summary>
					<p>
						Variable fonts are processed as their default style, and you'll see a note when
						that happens. For a full family (Bold, Light, Italic…), upload the whole zip — the
						fixed-weight fonts in its <code>static/</code> folder carry every style through.
					</p>
				</details>
				<details>
					<summary>Am I allowed to modify a font?</summary>
					<p>
						That depends on the font's license. Open licenses like the SIL Open Font License
						explicitly allow modification. For commercial fonts, check your license terms
						first. Since nothing leaves your computer, Ecofonts itself never redistributes
						anything.
					</p>
				</details>
			</div>
		</section>
	</main>

	<script>
		import { stashFiles } from "../lib/handoff";
		import { validateSelection } from "../lib/limits";

		const zone = document.getElementById("dropzone");
		const input = document.getElementById("drop-input") as HTMLInputElement | null;
		const error = document.getElementById("drop-error");

		async function send(list: FileList | null | undefined): Promise<void> {
			const candidates = Array.from(list ?? []);
			if (candidates.length === 0) return;
			const { accepted, error: validationError } = validateSelection(candidates);
			if (validationError || accepted.length === 0) {
				if (error) {
					error.textContent =
						validationError ??
						"Please choose .pdf documents, .zip archives, or fonts (.ttf, .otf, .woff, .woff2).";
					error.removeAttribute("hidden");
				}
				return;
			}
			error?.setAttribute("hidden", "");
			try {
				await stashFiles(accepted);
			} catch {
				// If storage fails the user can simply re-pick the files on /font.
			}
			window.location.href = "/font";
		}

		if (zone && input) {
			zone.addEventListener("click", () => input.click());
			zone.addEventListener("keydown", (event) => {
				if (event.key === "Enter" || event.key === " ") {
					event.preventDefault();
					input.click();
				}
			});
			input.addEventListener("change", () => void send(input.files));
			zone.addEventListener("dragover", (event) => {
				event.preventDefault();
				zone.classList.add("dragover");
			});
			zone.addEventListener("dragleave", () => zone.classList.remove("dragover"));
			zone.addEventListener("drop", (event) => {
				event.preventDefault();
				zone.classList.remove("dragover");
				void send(event.dataTransfer?.files);
			});
		}
	</script>

	<style>
		.hero {
			position: relative;
			max-width: 760px;
			margin: 0 auto;
			padding: 64px 24px 72px;
			text-align: center;
		}
		.hero::before {
			content: "";
			position: absolute;
			inset: -120px 0 auto 0;
			height: 420px;
			background: radial-gradient(ellipse 60% 55% at 50% 0%, var(--glow), transparent 70%);
			pointer-events: none;
			z-index: -1;
		}
		.badge {
			display: inline-block;
			margin: 0 0 20px;
			padding: 6px 16px;
			border-radius: 999px;
			border: 1px solid var(--border);
			background: var(--surface);
			color: var(--muted);
			font-size: 0.85rem;
			font-weight: 600;
		}
		h1 {
			font-size: clamp(2.4rem, 6vw, 3.8rem);
			line-height: 1.08;
			letter-spacing: -0.03em;
			margin: 0 0 18px;
		}
		.accent {
			background: linear-gradient(120deg, var(--green), var(--green-bright));
			-webkit-background-clip: text;
			background-clip: text;
			color: transparent;
		}
		.tagline {
			font-size: 1.15rem;
			color: var(--muted);
			margin: 0 auto 36px;
			max-width: 600px;
		}

		#dropzone {
			max-width: 540px;
			margin: 0 auto;
			padding: 44px 24px;
			border: 2px dashed var(--green);
			border-radius: 20px;
			background: var(--tint);
			cursor: pointer;
			transition:
				background 0.15s,
				transform 0.15s,
				box-shadow 0.15s;
		}
		#dropzone:hover,
		#dropzone:focus-visible,
		#dropzone.dragover {
			background: var(--tint-strong);
			transform: translateY(-3px);
			box-shadow: var(--shadow);
			outline: none;
		}
		#dropzone p {
			margin: 10px 0 0;
			font-size: 1.05rem;
		}
		#dropzone .hint {
			color: var(--muted);
			font-size: 0.95rem;
			margin-top: 4px;
		}
		#drop-error {
			color: var(--error-ink);
			margin-top: 14px;
		}
		.stats {
			list-style: none;
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 10px;
			margin: 28px 0 0;
			padding: 0;
		}
		.stats li {
			padding: 7px 16px;
			border-radius: 999px;
			border: 1px solid var(--border);
			background: var(--surface);
			color: var(--muted);
			font-size: 0.9rem;
		}
		.stats strong {
			color: var(--ink);
		}

		main section {
			padding: 72px 24px;
		}
		main section.alt {
			background: var(--bg-soft);
			border-top: 1px solid var(--border);
			border-bottom: 1px solid var(--border);
		}
		h2 {
			text-align: center;
			font-size: clamp(1.7rem, 3.5vw, 2.2rem);
			letter-spacing: -0.02em;
			margin: 0 0 14px;
		}
		.section-lede {
			text-align: center;
			color: var(--muted);
			max-width: 560px;
			margin: 0 auto 40px;
		}
		section > .grid {
			margin-top: 40px;
		}
		.grid {
			display: grid;
			gap: 20px;
			max-width: 1080px;
			margin: 0 auto;
		}
		.grid.three {
			grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		}
		.grid.four {
			grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
		}
		.card {
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: 18px;
			padding: 26px;
			transition:
				transform 0.15s,
				box-shadow 0.15s,
				border-color 0.15s;
		}
		.card:hover {
			transform: translateY(-3px);
			box-shadow: var(--shadow);
			border-color: var(--green);
		}
		.card h3 {
			margin: 0 0 8px;
			font-size: 1.08rem;
		}
		.card p {
			margin: 0;
			color: var(--muted);
			font-size: 0.96rem;
		}
		.step {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 34px;
			height: 34px;
			border-radius: 50%;
			background: linear-gradient(135deg, var(--green), var(--green-bright));
			color: #04160c;
			font-weight: 800;
			margin-bottom: 14px;
		}

		.gf-steps {
			max-width: 640px;
			margin: 0 auto;
			padding: 0;
			list-style: none;
			counter-reset: gf;
		}
		.gf-steps li {
			counter-increment: gf;
			position: relative;
			padding: 18px 20px 18px 66px;
			margin-bottom: 14px;
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: 16px;
			color: var(--muted);
		}
		.gf-steps li strong {
			color: var(--ink);
		}
		.gf-steps li::before {
			content: counter(gf);
			position: absolute;
			left: 18px;
			top: 50%;
			transform: translateY(-50%);
			width: 32px;
			height: 32px;
			display: flex;
			align-items: center;
			justify-content: center;
			border-radius: 50%;
			background: linear-gradient(135deg, var(--green), var(--green-bright));
			color: #04160c;
			font-weight: 800;
		}
		.gf-steps a {
			color: var(--green-hover);
			font-weight: 600;
		}

		.mission-close {
			text-align: center;
			max-width: 560px;
			margin: 36px auto 0;
			font-size: 1.05rem;
			font-weight: 650;
		}

		.faq-list {
			max-width: 720px;
			margin: 0 auto;
			/* Lets block-size animate to `auto` in the expand transition below. */
			interpolate-size: allow-keywords;
		}
		details {
			border: 1px solid var(--border);
			border-radius: 14px;
			background: var(--surface);
			padding: 4px 20px;
			margin-bottom: 12px;
			transition:
				border-color 0.15s,
				box-shadow 0.15s;
		}
		details:hover,
		details[open] {
			border-color: var(--green);
		}
		details[open] {
			box-shadow: var(--shadow);
		}
		summary {
			position: relative;
			cursor: pointer;
			font-weight: 650;
			padding: 14px 38px 14px 0;
			list-style: none;
			transition: color 0.15s;
		}
		summary::-webkit-details-marker {
			display: none;
		}
		summary:hover,
		details[open] summary {
			color: var(--green-hover);
		}
		/* +/- indicator: two bars; the vertical one rotates flat when open. */
		summary::before,
		summary::after {
			content: "";
			position: absolute;
			right: 6px;
			top: 50%;
			width: 14px;
			height: 2px;
			border-radius: 1px;
			background: var(--green);
			transform: translateY(-50%);
			transition: transform 0.25s ease;
		}
		summary::after {
			transform: translateY(-50%) rotate(90deg);
		}
		details[open] summary::after {
			transform: translateY(-50%) rotate(0deg);
		}
		/* Smooth expand where ::details-content is supported; elsewhere the
		   answer simply toggles instantly, as before. */
		details::details-content {
			opacity: 0;
			block-size: 0;
			overflow: hidden;
			transition:
				content-visibility 0.3s allow-discrete,
				opacity 0.2s ease,
				block-size 0.3s ease;
		}
		details[open]::details-content {
			opacity: 1;
			block-size: auto;
		}
		details p {
			margin: 0 0 18px;
			color: var(--muted);
		}
		details a {
			color: var(--green-hover);
		}
		@media (prefers-reduced-motion: reduce) {
			summary::before,
			summary::after,
			details::details-content {
				transition: none;
			}
		}
